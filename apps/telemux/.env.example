# Copy this file to .env and fill in the Telegram token.
# The service reads .env directly with systemd EnvironmentFile.

FACTORY_TELEGRAM_BOT_TOKEN=
# Optional. Set this to the control supergroup chat id to register chat_member command scope on startup.
# FACTORY_TELEGRAM_CONTROL_CHAT_ID=-1001234567890
# Set this to the Telegram user id that is allowed to control the bot.
FACTORY_ALLOWED_TELEGRAM_USER_ID=123456789
FACTORY_DASHBOARD_HOST=127.0.0.1
FACTORY_DASHBOARD_PORT=8787
FACTORY_TELEGRAM_POLL_TIMEOUT_SECONDS=30
FACTORY_TEXT_COALESCE_MS=1500
FACTORY_TEXT_COALESCE_RECOVERY_MAX_AGE_MS=300000
# Deterministic pre-dispatch routing is always active. Set this to 1 to enable
# the optional cheap LLM classifier for ambiguous short plain-text messages.
# When enabled, message text and minimal context metadata are sent to OpenAI's Responses API.
FACTORY_PRE_DISPATCH_CLASSIFIER=0
FACTORY_PRE_DISPATCH_CLASSIFIER_MODEL=gpt-5.4-mini
FACTORY_PRE_DISPATCH_CLASSIFIER_REASONING_EFFORT=minimal
FACTORY_PRE_DISPATCH_CLASSIFIER_TIMEOUT_MS=800
FACTORY_PRE_DISPATCH_CLASSIFIER_MAX_CHARS=600
FACTORY_PRE_DISPATCH_CLASSIFIER_CONFIDENCE=0.75
FACTORY_PRE_DISPATCH_CLASSIFIER_API_KEY=
FACTORY_CRON_POLL_INTERVAL_SECONDS=30
FACTORY_LOCAL_MACHINE=control
BRAINSTACK_STATE_ROOT=~/.local/state/brainstack
FACTORY_CONTROL_ROOT=~/.local/state/brainstack/telemux
FACTORY_FACTORY_ROOT=~/.local/state/brainstack/factory
# Optional override. Default worker config path is ./workers.json
# FACTORY_WORKERS_FILE=./workers.json
FACTORY_USAGE_ADAPTER=manual
# Harness may be codex or claude. FACTORY_HARNESS_BIN may be an absolute path.
FACTORY_HARNESS=codex
FACTORY_HARNESS_BIN=codex
# Backward-compatible Codex override used only when FACTORY_HARNESS=codex.
FACTORY_CODEX_BIN=codex
